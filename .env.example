TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# Admin Credentials for Render (Sets admin user automatically)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# Binance API (NOT Merchant - yeh API Key + Secret wala hai)
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
# Admin ka Binance USDT deposit address jahan user bhejega
BINANCE_DEPOSIT_ADDRESS=your-binance-usdt-deposit-address

SITE_LOGO_URL=https://i.postimg.cc/tCDgJy6Y/IMG-20260628-153910-667.jpg

PORT=5000
